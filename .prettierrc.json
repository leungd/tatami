{
  "plugins": ["prettier-plugin-tailwindcss", "@ttskch/prettier-plugin-tailwindcss-anywhere", "@zackad/prettier-plugin-twig"],
  "twigAlwaysBreakObjects": true,
  "twigSingleQuote": true,
  "overrides": [
    {
      "files": "*.twig",
      "options": {
        "parser": "anywhere"
      }
    }
  ]
}

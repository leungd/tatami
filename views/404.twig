{% extends 'base.twig' %}

{% block hero %}
  {% embed 'partials/hero.twig'
    with {
      title
    }
  %}
    {% block heroBody %}
      <h1>{{ title }}</h1>
    {% endblock %}
  {% endembed %}
{% endblock %}

{% block content %}
  <div class="fluid-grid">
    <div class="col-[content-start/content-end]">
      <p>
        {{ __("Sorry, we couldn't find what you're looking for.", 'tatami') }}
      </p>
      <a href="{{ site.home_url }}">{{ __('Return to Home', 'tatami') }}</a>
    </div>
  </div>
{% endblock %}

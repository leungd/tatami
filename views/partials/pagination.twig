{% if posts.pagination.pages is not empty %}
	<nav class="col-[content-start/content-end] mt-8 flex justify-center" aria-label="Pagination Navigation">
		<div
			class="flex gap-1 items-center p-1 bg-white rounded-lg border border-gray-200">

			{# Previous Button #}
			{% if posts.pagination.prev %}
<a href="{{ posts.pagination.prev.link }}" class="flex gap-2 items-center px-3 py-2 text-sm font-medium text-gray-600 rounded-md transition-all duration-200 group hover:text-blue-600 hover:bg-blue-50">
					<svg class="w-4 h-4 transition-transform group-hover:-translate-x-0.5" fill="none" stroke="currentColor" viewbox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
					</svg>
					<span class="hidden sm:inline">Previous</span>
				</a>
			{% else %}
				<span class="flex gap-2 items-center px-3 py-2 text-sm font-medium text-gray-300 rounded-md cursor-not-allowed">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewbox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
					</svg>
					<span class="hidden sm:inline">Previous</span>
				</span>
			{% endif %}

			{# Page Numbers #}
			<div class="hidden gap-1 items-center mx-2 md:flex">
				{% for page in posts.pagination.pages %}
					{% if page.link %}
						{% if 'current' in page.class %}
							{# Current Page #}
<span class="relative px-3 py-2 text-sm font-semibold text-white rounded-md shadow-sm bg-blue-600">
								{{ page.title }}
							</span>
						{% elseif page.title == '…' %}
							{# Ellipsis #}
							<span class="px-2 py-2 text-sm text-gray-400 pointer-events-none">
								{{ page.title }}
							</span>
						{% else %}
							{# Regular Page Link #}
<a href="{{ page.link }}" class="px-3 py-2 text-sm font-medium text-gray-600 rounded-md transition-all duration-200 hover:text-blue-600 hover:bg-blue-50">
								{{ page.title }}
							</a>
						{% endif %}
					{% else %}
						{% if 'current' in page.class %}
<span class="relative px-3 py-2 text-sm font-semibold text-white rounded-md shadow-sm bg-blue-600">
								{{ page.title }}
							</span>
						{% else %}
							<span class="px-2 py-2 text-sm text-gray-400">
								{{ page.title }}
							</span>
						{% endif %}
					{% endif %}
				{% endfor %}
			</div>

			{# Mobile Page Info #}
			<div class="flex items-center px-3 py-2 text-sm text-gray-600 md:hidden">
				<span class="font-medium">Page
					{{ posts.pagination.current }}</span>
				<span class="mx-1 text-gray-400">of</span>
				<span class="font-medium">{{ posts.pagination.total }}</span>
			</div>

			{# Next Button #}
			{% if posts.pagination.next %}
<a href="{{ posts.pagination.next.link }}" class="flex gap-2 items-center px-3 py-2 text-sm font-medium text-gray-600 rounded-md transition-all duration-200 group hover:text-blue-600 hover:bg-blue-50">
					<span class="hidden sm:inline">Next</span>
					<svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewbox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
					</svg>
				</a>
			{% else %}
				<span class="flex gap-2 items-center px-3 py-2 text-sm font-medium text-gray-300 rounded-md cursor-not-allowed">
					<span class="hidden sm:inline">Next</span>
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewbox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
					</svg>
				</span>
			{% endif %}

		</div>
	</nav>
{% endif %}
